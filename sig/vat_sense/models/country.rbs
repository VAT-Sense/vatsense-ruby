module VatSense
  module Models
    type country =
      {
        country_code: String,
        country_name: String,
        eu: bool,
        latitude: Float,
        longitude: Float,
        object: VatSense::Models::Country::object,
        vat: bool
      }

    class Country < VatSense::Internal::Type::BaseModel
      attr_reader country_code: String?

      def country_code=: (String) -> String

      attr_reader country_name: String?

      def country_name=: (String) -> String

      attr_reader eu: bool?

      def eu=: (bool) -> bool

      attr_reader latitude: Float?

      def latitude=: (Float) -> Float

      attr_reader longitude: Float?

      def longitude=: (Float) -> Float

      attr_reader object: VatSense::Models::Country::object?

      def object=: (
        VatSense::Models::Country::object
      ) -> VatSense::Models::Country::object

      attr_reader vat: bool?

      def vat=: (bool) -> bool

      def initialize: (
        ?country_code: String,
        ?country_name: String,
        ?eu: bool,
        ?latitude: Float,
        ?longitude: Float,
        ?object: VatSense::Models::Country::object,
        ?vat: bool
      ) -> void

      def to_hash: -> {
        country_code: String,
        country_name: String,
        eu: bool,
        latitude: Float,
        longitude: Float,
        object: VatSense::Models::Country::object,
        vat: bool
      }

      type object = :country

      module Object
        extend VatSense::Internal::Type::Enum

        COUNTRY: :country

        def self?.values: -> ::Array[VatSense::Models::Country::object]
      end
    end
  end
end
